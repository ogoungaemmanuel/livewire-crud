{
    "name": "xslainadmin/livewire-crud",
    "description": "Enterprise Laravel Livewire CRUD generator with advanced analytics, calendar management, export/import capabilities, notification systems, and modern Bootstrap 5 UI. Perfect for rapid application development with production-ready components.",
    "keywords": [
        "laravel",
        "livewire",
        "crud",
        "generator",
        "bootstrap",
        "charts",
        "calendar",
        "export",
        "import",
        "notifications",
        "alpine",
        "apexcharts",
        "fullcalendar",
        "enterprise",
        "admin",
        "dashboard",
        "scaffolding",
        "rapid-development",
        "horizon",
        "pulse",
        "search",
        "redis",
        "data-transfer-objects",
        "query-builder",
        "telescope",
        "activity-log",
        "permissions",
        "rbac",
        "audit",
        "monitoring"
    ],
    "homepage": "https://github.com/ogoungaemmanuel/livewire-crud",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Ogounga Emmanuel",
            "email": "info@xslain.com",
            "homepage": "https://github.com/ogoungaemmanuel",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2|^8.3|^8.4",
        "laravel/framework": "^10.0|^11.0|^12.0",
        "livewire/livewire": "^3.0|^4.0",
        "laravel/ui": "^4.0|^5.0",
        "php-flasher/flasher-laravel": "^2.1",
        "intervention/image": "^3.0|^4.0",
        "maatwebsite/excel": "^3.1",
        "barryvdh/laravel-dompdf": "^2.0|^3.1",
        "spatie/laravel-activitylog": "^4.7|^5.0",
        "spatie/laravel-data": "^4.0|^5.0",
        "spatie/laravel-permission": "^6.0|^7.0"
    },
    "require-dev": {
        "rector/rector": "^2.1",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "mockery/mockery": "^1.4|^2.0",
        "laravel/pint": "^1.0|^2.0",
        "laravel/telescope": "^5.0",
        "nunomaduro/collision": "^7.0|^8.0|^9.0",
        "pestphp/pest": "^2.0|^3.0",
        "pestphp/pest-plugin-arch": "^2.0|^3.0",
        "pestphp/pest-plugin-laravel": "^2.0|^3.0",
        "brianium/paratest": "^7.0|^8.0",
        "spatie/laravel-ray": "^1.32|^2.0",
        "fakerphp/faker": "^1.21|^2.0",
        "phpstan/phpstan": "^1.10|^2.0",
        "larastan/larastan": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Xslainadmin\\LivewireCrud\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Xslainadmin\\LivewireCrud\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage --min=80",
        "test-unit": "vendor/bin/pest --testsuite=Unit",
        "test-feature": "vendor/bin/pest --testsuite=Feature",
        "test-parallel": "vendor/bin/paratest --runner=WrapperRunner",
        "test-arch": "vendor/bin/pest --filter=arch",
        "test-type-coverage": "vendor/bin/pest --type-coverage --min=100",
        "format": "vendor/bin/pint",
        "format-check": "vendor/bin/pint --test",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "analyse-baseline": "vendor/bin/phpstan analyse --generate-baseline",
        "rector": "vendor/bin/rector process",
        "rector-dry": "vendor/bin/rector process --dry-run",
        "security": "composer audit",
        "quality": [
            "@security",
            "@format-check",
            "@analyse",
            "@test-coverage"
        ],
        "ci": [
            "@security",
            "@format-check",
            "@analyse",
            "@rector-dry",
            "@test-parallel"
        ],
        "setup-hooks": [
            "cp .github/hooks/pre-commit .git/hooks/pre-commit",
            "chmod +x .git/hooks/pre-commit"
        ],
        "post-install-cmd": [
            "@php artisan vendor:publish --provider=\"Xslainadmin\\LivewireCrud\\LivewireCrudServiceProvider\" --tag=config --force"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform": {
            "php": "8.2"
        },
        "audit": {
            "abandoned": "report"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "laravel/horizon": "Queue monitoring dashboard (requires ext-pcntl on Linux/macOS)",
        "laravel/telescope": "Request/query debugging tool for local development",
        "laravel/pulse": "Application performance monitoring dashboard",
        "laravel/scout": "Full-text search integration (Algolia, Meilisearch, etc.)",
        "spatie/laravel-query-builder": "Build Eloquent queries from API requests",
        "predis/predis": "PHP Redis client for Redis-based caching/queues",
        "pusher/pusher-php-server": "Pusher broadcasting driver for real-time events"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Xslainadmin\\LivewireCrud\\LivewireCrudServiceProvider"
            ],
            "aliases": {
                "LivewireCrud": "Xslainadmin\\LivewireCrud\\LivewireCrudFacade"
            }
        },
        "branch-alias": {
            "dev-main": "4.1-dev"
        }
    },
    "support": {
        "issues": "https://github.com/ogoungaemmanuel/livewire-crud/issues",
        "source": "https://github.com/ogoungaemmanuel/livewire-crud",
        "docs": "https://ogoungaemmanuel.github.io/livewire-crud",
        "chat": "https://github.com/ogoungaemmanuel/livewire-crud/discussions"
    },
    "funding": [
        {
            "type": "github",
            "url": "https://github.com/sponsors/ogoungaemmanuel"
        },
        {
            "type": "paypal",
            "url": "https://paypal.me/ogoungaemmanuel"
        }
    ]
}
